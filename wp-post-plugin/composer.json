{
    "name": "kesslemi/wp-post-plugin",
    "description": "Swiss Post barcodes and address labels for WordPress (WooCommerce optional).",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1",
        "setasign/fpdi": "^2.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "brain/monkey": "^2.6"
    },
    "autoload": {
        "psr-4": {
            "WPPost\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WPPost\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
