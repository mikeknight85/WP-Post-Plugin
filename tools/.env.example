# Copy this file to tools/.env and fill in real values (.env is gitignored).

# === Swiss Post API credentials (from developer.post.ch → your app) ===
WPP_CLIENT_ID=
WPP_CLIENT_SECRET=

# Optional: APIM subscription / primary key. Some Swiss Post APIs require this
# in addition to the OAuth Bearer token. If your app on developer.post.ch shows
# a "Primary key" / "Subscription key", paste it here. Leave empty otherwise.
WPP_SUBSCRIPTION_KEY=

# Franking licence (Frankierlizenz) from your Swiss Post contract — digits only.
WPP_FRANKING_LICENSE=

# 'test' = printPreview true (free SPECIMEN, never billed)
# 'prod' = printPreview false (billable real labels)
WPP_ENV=test

# === Sender address (your business; appears as return address on the label) ===
WPP_SENDER_NAME=ONEBEAR
WPP_SENDER_STREET=Bottigenstrasse
WPP_SENDER_HOUSE_NO=273a
WPP_SENDER_ZIP=3019
WPP_SENDER_CITY=Bern
WPP_SENDER_COUNTRY=CH

# === Recipient (defaults to a synthetic Zurich address — override if you want) ===
WPP_RECIPIENT_NAME=Max Muster
WPP_RECIPIENT_STREET=Bahnhofstrasse
WPP_RECIPIENT_HOUSE_NO=1
WPP_RECIPIENT_ZIP=8001
WPP_RECIPIENT_CITY=Zurich
WPP_RECIPIENT_COUNTRY=CH
